# ─── Obrigatório ──────────────────────────────────────────────────────────────
GROQ_API_KEY=sua_chave_aqui
CONFIG_PATH=./configs/meu-negocio.json

# ─── Opcional ─────────────────────────────────────────────────────────────────

# Nível de log: DEBUG | INFO | WARN | ERROR  (padrão: INFO)
LOG_LEVEL=INFO

# Timeout da chamada à API do Groq em milissegundos (padrão: 15000)
GROQ_TIMEOUT_MS=15000

# Intervalo do serviço de lembretes automáticos em milissegundos (padrão: 60000 = 1 min)
REMINDER_INTERVAL_MS=60000
